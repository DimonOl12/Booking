<!-- ══ Similar properties ════════════════════════════════════ -->
@if (Model.SimilarListings.Any())
{
    <div class="prop-container">
        <section class="prop-similar">
            <h2 class="prop-section-title">Схожі помешкання в @l.City</h2>
            <div class="prop-similar-scroll">
                @foreach (var sim in Model.SimilarListings)
                {
                    var simRating = sim.RatingScore.ToString("0.0").Replace('.', ',');
                    <article class="sim-card" onclick="window.location.href='/Home/Property/@sim.Id'">
                        <div class="sim-img-wrap">
                            <img src="@sim.ImageUrl" alt="@sim.Name" loading="lazy" />
                        </div>
                        <div class="sim-body">
                            <div class="sim-rating-row">
                                <div class="sim-badge">@simRating</div>
                                <span class="sim-rl">@sim.RatingLabel</span>
                                <span class="sim-rr">@sim.ReviewsCount відгуків</span>
                            </div>
                            <h3 class="sim-name">@sim.Name</h3>
                            <p class="sim-loc">@sim.Location</p>
                            <div class="sim-footer">
                                <span class="sim-price">UAH @sim.PricePerNight.ToString("N0")</span>
                                <span class="sim-price-meta">за ніч</span>
                            </div>
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>
}

@await Html.PartialAsync("_Footer")

<!-- Map modal (reused from search page) -->
<div class="map-modal" id="propMapModal" style="display:none">
    <div class="map-modal-inner">
        <div class="map-area-panel" style="flex:1;position:relative;">
            <div id="propLeafletMap" style="width:100%;height:100%;"></div>
            <button class="btn-return-map" id="propCloseMapBtn">← Повернутись</button>
        </div>
    </div>
</div>

<script>
    window._propListing = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
        id              = l.Id,
        name            = l.Name,
        location        = l.Location,
        city            = l.City,
        pricePerNight   = l.PricePerNight,
        ratingScore     = l.RatingScore,
        imageUrl        = l.ImageUrl
    }));
</script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="~/js/property.js"></script>
