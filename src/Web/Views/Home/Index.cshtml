@{
    ViewData["Title"] = "Головна";
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reservio - Бронювання житла</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700&family=Unbounded:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/home.css" />
    <link rel="stylesheet" href="~/css/search.css" />
</head>
<body>


    <section class="hero-section">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            @await Html.PartialAsync("_HomeNavbar")
        }
        else
        {
            @await Html.PartialAsync("_HomeNavbarGuest")
        }

        <div class="hero-text">
            <h1 class="hero-title">Знайдіть ідеальне житло за 2 хвилини</h1>
            <p class="hero-subtitle">Понад 10 000 перевірених помешкань в Україні та Європі</p>
        </div>
    </section>


    <div class="search-bg">
    <div class="search-card-wrapper">
        <div class="search-card">
            <div class="search-tabs">
                <button class="search-tab active">Помешкання</button>
                <button class="search-tab">Переліт</button>
                <button class="search-tab">Оренда авто</button>
                <button class="search-tab">Дозвілля</button>
                <button class="search-tab">Таксі з/до аеропорту</button>
            </div>
            <form class="search-inputs-row" id="homeSearchForm" method="get" action="/Home/Search">
                <div class="search-input-group" style="flex:2;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input type="text" name="city" id="homeCity" placeholder="Куди ви вирушаєте?" autocomplete="off" maxlength="100" />
                    <input type="hidden" name="adults"   id="homeAdults"   value="2" />
                    <input type="hidden" name="children" id="homeChildren" value="0" />
                    <input type="hidden" name="rooms"    id="homeRooms"    value="1" />
                    <input type="hidden" name="checkIn"  id="homeCheckIn"  value="" />
                    <input type="hidden" name="checkOut" id="homeCheckOut" value="" />
                </div>

                <div class="search-input-group" id="homeDateField" style="cursor:pointer;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8" y1="2" x2="8" y2="6"/>
                        <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    <span id="homeDateLabel" class="search-text">Дата заїзду &ndash; Дата виїзду</span>
                </div>

                <div class="search-input-group" id="homeGuestsField" style="cursor:pointer;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                        <path d="M16 3.13a4 4 0 010 7.75"/>
                    </svg>
                    <span id="homeGuestsLabel" class="search-text">2 дорослих &middot; 0 дітей &middot; 1 номер</span>
                    <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </div>
            </form>

            <div class="search-btn-wrapper">
                <button class="search-btn" onclick="document.getElementById('homeSearchForm').submit()">Шукати</button>
            </div>
        </div>

    <!-- Date picker popup (home) — inside wrapper for correct absolute positioning -->
    <div class="home-popup datepicker-popup" id="homeDatepickerPopup" style="display:none; position:absolute; left:0; right:0; z-index:300;">
        <div class="dp-months">
            <div class="dp-month" id="hdpMonth1"></div>
            <div class="dp-month" id="hdpMonth2"></div>
        </div>
        <div class="dp-footer">
            <button class="dp-clear" id="hdpClear">Очистити</button>
            <button class="dp-done" id="hdpDone">Готово</button>
        </div>
    </div>

    <!-- Guests popup (home) -->
    <div class="home-popup guests-popup" id="homeGuestsPopup" style="display:none; position:absolute; z-index:300; right:0;">
        <div class="gp-row">
            <div class="gp-label">
                <span class="gp-title">Дорослі</span>
                <span class="gp-sub">Від 18 років</span>
            </div>
            <div class="gp-counter">
                <button class="gp-btn" data-target="adults" data-action="dec">−</button>
                <span id="hgp-adults">2</span>
                <button class="gp-btn" data-target="adults" data-action="inc">+</button>
            </div>
        </div>
        <div class="gp-row">
            <div class="gp-label">
                <span class="gp-title">Діти</span>
                <span class="gp-sub">0–17 років</span>
            </div>
            <div class="gp-counter">
                <button class="gp-btn" data-target="children" data-action="dec">−</button>
                <span id="hgp-children">0</span>
                <button class="gp-btn" data-target="children" data-action="inc">+</button>
            </div>
        </div>
        <div class="gp-row">
            <div class="gp-label">
                <span class="gp-title">Номери</span>
            </div>
            <div class="gp-counter">
                <button class="gp-btn" data-target="rooms" data-action="dec">−</button>
                <span id="hgp-rooms">1</span>
                <button class="gp-btn" data-target="rooms" data-action="inc">+</button>
            </div>
        </div>
        <button class="gp-done" id="hgpDone">Готово</button>
    </div>
    </div><!-- /search-card-wrapper -->
    </div><!-- /search-bg -->


    <div class="section section--promo">
        <h2 class="section-title">Акції на проживання</h2>

        <div class="promo-grid">
            <div class="promo-card">
                <div>
                    <span class="promo-tag">ВАШ НОВИЙ ОФІС</span>
                    <h3 class="promo-title">Знижка -25% при бронюванні від 7 днів</h3>
                    <ul class="promo-bullets">
                        <li>Безлімітна кава для драйву</li>
                        <li>Комфортна робоча зона</li>
                        <li>Стабільний Wi-Fi</li>
                    </ul>
                </div>
                <a href="/Home/Search" class="btn-promo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
            </div>

            <div class="promo-card">
                <div>
                    <span class="promo-tag">ПЛАНУЙТЕ ЗАЗДАЛЕГІДЬ</span>
                    <h3 class="promo-title">Знижка -15% при бронюванні за 30 днів до візиту</h3>
                    <p class="promo-desc">Зафіксуйте найкращу ціну сезону вже сьогодні!</p>
                </div>
                <a href="/Home/Search" class="btn-promo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
            </div>

            <div class="promo-card">
                <div>
                    <span class="promo-tag">АКЦІЯ &laquo;3+1&raquo;</span>
                    <h3 class="promo-title">Забронюйте 4 ночі &mdash; сплатіть лише за 3!</h3>
                    <p class="promo-desc">Обирайте тариф &laquo;Спецпропозиція 3+1&raquo; у меню бронювання</p>
                </div>
                <a href="/Home/Search" class="btn-promo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
            </div>
        </div>
    </div>


    <div class="section">
        <h2 class="section-title">Сплануйте поїздку швидко та просто</h2>
        <p class="section-subtitle">Виберіть тип відпочинку та відвідайте найкращі місця в Україні</p>

        <div class="category-pills">
            <button class="category-pill active">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M21 9H3"/></svg>
                Місто
            </button>
            <button class="category-pill">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>
                    <path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>
                    <path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>
                </svg>
                Пляж
            </button>
            <button class="category-pill">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
                Активний відпочинок
            </button>
            <button class="category-pill">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
                Спокійний відпочинок
            </button>
            <button class="category-pill">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                Романтика
            </button>
            <button class="category-pill">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
                Їжа
            </button>
            <div class="nav-arrows" style="margin-left: auto;">
                <button class="arrow-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                </button>
                <button class="arrow-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
            </div>
        </div>

        <div class="city-grid" id="cityGrid">
            <!-- Місто -->
            <a href="/Home/Search?city=Львів" class="city-card" data-type="місто романтика їжа">
                <img src="/images/lviv.jpg" alt="Львів" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Львів</div>
                    <div class="city-card-distance">350+ місць</div>
                </div>
            </a>
            <a href="/Home/Search?city=Кам%27янець-Подільський" class="city-card" data-type="місто романтика активний">
                <img src="/images/kamianets.jpg" alt="Кам'янець-Подільський" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Кам'янець-Подільський</div>
                    <div class="city-card-distance">45+ місць</div>
                </div>
            </a>
            <a href="/Home/Search?city=Київ" class="city-card" data-type="місто їжа">
                <img src="/images/kyiv.jpg" alt="Київ" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Київ</div>
                    <div class="city-card-distance">500+ місць</div>
                </div>
            </a>
            <a href="/Home/Search?city=Закопане" class="city-card" data-type="місто активний спокійний">
                <img src="/images/zhytomyr.jpg" alt="Закопане" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Закопане</div>
                    <div class="city-card-distance">100+ місць</div>
                </div>
            </a>
            <!-- Пляж -->
            <a href="/Home/Search?city=Одеса" class="city-card" data-type="пляж їжа" style="display:none">
                <img src="/images/warsaw.jpg" alt="Одеса" onerror="this.src='https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Одеса</div>
                    <div class="city-card-distance">280+ місць</div>
                </div>
            </a>
            <a href="/Home/Search?city=Бердянськ" class="city-card" data-type="пляж спокійний" style="display:none">
                <img src="/images/chisinau.jpg" alt="Бердянськ" onerror="this.src='https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Бердянськ</div>
                    <div class="city-card-distance">60+ місць</div>
                </div>
            </a>
            <a href="/Home/Search?city=Кирилівка" class="city-card" data-type="пляж" style="display:none">
                <img src="/images/warsaw.jpg" alt="Кирилівка" onerror="this.src='https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Кирилівка</div>
                    <div class="city-card-distance">35+ місць</div>
                </div>
            </a>
            <a href="/Home/Search?city=Залізний+Порт" class="city-card" data-type="пляж" style="display:none">
                <img src="/images/kyiv.jpg" alt="Залізний Порт" onerror="this.src='https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Залізний Порт</div>
                    <div class="city-card-distance">25+ місць</div>
                </div>
            </a>
            <!-- Активний відпочинок -->
            <a href="/Home/Search?city=Буковель" class="city-card" data-type="активний" style="display:none">
                <img src="/images/lviv.jpg" alt="Буковель" onerror="this.src='https://images.unsplash.com/photo-1551698618-1dfe5d97d256?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Буковель</div>
                    <div class="city-card-distance">150+ місць</div>
                </div>
            </a>
            <a href="/Home/Search?city=Яремче" class="city-card" data-type="активний спокійний" style="display:none">
                <img src="/images/kyiv.jpg" alt="Яремче" onerror="this.src='https://images.unsplash.com/photo-1551698618-1dfe5d97d256?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Яремче</div>
                    <div class="city-card-distance">90+ місць</div>
                </div>
            </a>
            <a href="/Home/Search?city=Славське" class="city-card" data-type="активний" style="display:none">
                <img src="/images/kamianets.jpg" alt="Славське" onerror="this.src='https://images.unsplash.com/photo-1551698618-1dfe5d97d256?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Славське</div>
                    <div class="city-card-distance">50+ місць</div>
                </div>
            </a>
            <!-- Спокійний відпочинок -->
            <a href="/Home/Search?city=Трускавець" class="city-card" data-type="спокійний" style="display:none">
                <img src="/images/lviv.jpg" alt="Трускавець" onerror="this.src='https://images.unsplash.com/photo-1566073771259-6a8506099945?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Трускавець</div>
                    <div class="city-card-distance">70+ місць</div>
                </div>
            </a>
            <a href="/Home/Search?city=Берегове" class="city-card" data-type="спокійний романтика" style="display:none">
                <img src="/images/kamianets.jpg" alt="Берегове" onerror="this.src='https://images.unsplash.com/photo-1566073771259-6a8506099945?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Берегове</div>
                    <div class="city-card-distance">30+ місць</div>
                </div>
            </a>
            <!-- Романтика -->
            <a href="/Home/Search?city=Чернівці" class="city-card" data-type="романтика їжа" style="display:none">
                <img src="/images/kyiv.jpg" alt="Чернівці" onerror="this.src='https://images.unsplash.com/photo-1470770841072-f978cf4d019e?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Чернівці</div>
                    <div class="city-card-distance">80+ місць</div>
                </div>
            </a>
            <a href="/Home/Search?city=Ужгород" class="city-card" data-type="романтика спокійний" style="display:none">
                <img src="/images/zhytomyr.jpg" alt="Ужгород" onerror="this.src='https://images.unsplash.com/photo-1470770841072-f978cf4d019e?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Ужгород</div>
                    <div class="city-card-distance">65+ місць</div>
                </div>
            </a>
            <!-- Їжа -->
            <a href="/Home/Search?city=Харків" class="city-card" data-type="їжа місто" style="display:none">
                <img src="/images/kyiv.jpg" alt="Харків" onerror="this.src='https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=500&q=80'" />
                <div class="city-card-overlay"></div>
                <div class="city-card-info">
                    <div class="city-card-name">Харків</div>
                    <div class="city-card-distance">200+ місць</div>
                </div>
            </a>
        </div>
    </div>



    <div class="section">
        <h2 class="section-title">Популярні напрямки</h2>

        <div class="dest-grid">
            <a href="/Home/Search?city=Варшава" class="dest-card">
                <img src="/images/warsaw.jpg" alt="Варшава" />
                <div class="dest-card-overlay"></div>
                <div class="dest-card-name">Варшава</div>
            </a>
            <a href="/Home/Search?city=Кишинів" class="dest-card">
                <img src="/images/chisinau.jpg" alt="Кишинів" />
                <div class="dest-card-overlay"></div>
                <div class="dest-card-name">Кишинів</div>
            </a>
        </div>
    </div>


    <div class="section">
        <div class="section-header">
            <h2 class="section-title section-title-sm">Забронюйте наші найпопулярніші унікальні помешкання</h2>
            <div class="nav-arrows">
                <button class="arrow-btn disabled">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                </button>
                <button class="arrow-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
            </div>
        </div>

        <div class="property-scroll">
            <div class="property-card" data-id="1" style="cursor:pointer">
                <div class="property-card-img">
