@model Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Вхід для партнерів";
    Layout = null;
    var hasError = ViewBag.Error != null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reservio — Вхід для партнерів</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700&family=Unbounded:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/home.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>
<div class="auth-page-figma">

    <div class="auth-hero-bg">
        <img src="~/images/Subtract.jpg" alt="" />
    </div>
    @await Html.PartialAsync("_HomeNavbarGuest")


    <main class="auth-main-figma">
        <form method="post" asp-action="RealtorLogin" asp-controller="Account">
            @Html.AntiForgeryToken()
            <div class="auth-card-figma">

                <div class="auth-form-content">

                    <div style="display:flex;flex-direction:column;align-items:center;gap:16px;width:100%;">
                        <h1 class="auth-heading-figma" style="text-align:center;">Увійдіть в акаунт, щоб керувати готельним об'єктом</h1>
                    </div>

                    <div class="auth-fields-group">

                        <div class="auth-field">
                            <div class="auth-field-label-row">
                                <label class="auth-field-label" for="Email">Електронна адреса</label>
                            </div>
                            <div class="auth-input-wrapper @(hasError ? "field-error" : "")">
                                <input type="email"
                                       class="auth-input-figma"
                                       id="Email"
                                       name="Email"
                                       value="@Model?.Email"
                                       placeholder="Введіть свою електронну адресу"
                                       autocomplete="email" />
                                @if (hasError)
                                {
                                    <span class="field-status-icon field-status-error">
                                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                            <circle cx="10" cy="10" r="9" stroke="#EB3D00" stroke-width="1.5"/>
                                            <line x1="10" y1="6" x2="10" y2="10.5" stroke="#EB3D00" stroke-width="1.5" stroke-linecap="round"/>
                                            <circle cx="10" cy="13.5" r="0.8" fill="#EB3D00"/>
                                        </svg>
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="auth-field">
                            <div class="auth-field-label-row">
                                <label class="auth-field-label" for="Password">Пароль</label>
                                <a href="@Url.Action("ForgotPassword", "Account")" class="auth-field-link">Забули пароль?</a>
                            </div>
                            <div class="auth-input-wrapper @(hasError ? "field-error" : "")">
                                <input type="password"
                                       class="auth-input-figma"
                                       id="Password"
                                       name="Password"
                                       placeholder="Введіть пароль"
                                       autocomplete="current-password" />
                                @if (hasError)
                                {
                                    <span class="field-status-icon field-status-error">
                                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                            <circle cx="10" cy="10" r="9" stroke="#EB3D00" stroke-width="1.5"/>
                                            <line x1="10" y1="6" x2="10" y2="10.5" stroke="#EB3D00" stroke-width="1.5" stroke-linecap="round"/>
                                            <circle cx="10" cy="13.5" r="0.8" fill="#EB3D00"/>
                                        </svg>
                                    </span>
                                }
                                else
                                {
                                    <button type="button" class="auth-eye-toggle" data-target="Password" aria-label="Показати/Сховати пароль">
                                        <svg id="eye-icon-Password" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                            <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                            <line x1="1" y1="1" x2="23" y2="23"/>
                                        </svg>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    @if (hasError)
                    {
                        <div class="auth-error-box">
                            <span class="auth-error-box-text">@ViewBag.Error</span>
                            <div class="auth-error-box-icon">
                                <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <circle cx="30" cy="30" r="28" fill="#F5EDE0" stroke="#D9C9A8" stroke-width="2"/>
                                    <ellipse cx="21" cy="26" rx="4" ry="5" fill="#223300"/>
                                    <ellipse cx="39" cy="26" rx="4" ry="5" fill="#223300"/>
                                    <ellipse cx="21" cy="25" rx="1.5" ry="2" fill="white"/>
                                    <ellipse cx="39" cy="25" rx="1.5" ry="2" fill="white"/>
                                    <path d="M20 38 Q30 33 40 38" stroke="#223300" stroke-width="2" stroke-linecap="round" fill="none"/>
                                    <path d="M16 20 Q19 17 22 20" stroke="#223300" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                                    <path d="M38 20 Q41 17 44 20" stroke="#223300" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                                </svg>
                            </div>
                        </div>
                    }

                    <button type="submit" class="auth-submit-btn">Продовжити</button>
                </div>

                <div class="rlt-login-footer">
                    <p style="font-family:'Rubik',sans-serif;font-size:14px;color:#000;text-align:center;">Ще не зареєстровані?</p>
                    <a href="@Url.Action("RealtorRegisterStep1", "Account")" class="rlt-register-btn">Створення акаунту партнера</a>
                </div>

                <div class="auth-footer-figma" style="margin-top:16px;">
                    <p class="auth-footer-text">
                        Входячи в акаунт або створюючи новий, ви погоджуєтеся з нашими
                        <a href="#">Правилами й умовами</a> та <a href="#">Політикою конфіденційності</a>
                    </p>
                    <p class="auth-footer-copy">Усі права захищено.</p>
                    <p class="auth-footer-copy">Copyright (2006 - 2026) - Reservio&#8482;</p>
                </div>

            </div>
        </form>
    </main>

</div>

<script>
(function () {
    document.querySelectorAll('.auth-eye-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var targetId = btn.getAttribute('data-target');
            var input = document.getElementById(targetId);
            var icon = document.getElementById('eye-icon-' + targetId);
            if (!input) return;
            var isPass = input.type === 'password';
            input.type = isPass ? 'text' : 'password';
            if (icon) {
                icon.innerHTML = isPass
                    ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
                    : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
            }
        });
    });
})();
</script>
</body>
</html>
