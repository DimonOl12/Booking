@model Web.Models.RealtorRegisterStep1ViewModel
@{
    ViewData["Title"] = "Реєстрація партнера — Крок 1";
    Layout = null;
    var hasError = ViewBag.Error != null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reservio — Реєстрація партнера</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700&family=Unbounded:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>
<div class="auth-page-figma">

    <div class="auth-hero-bg">
        <img src="~/images/Subtract.jpg" alt="" />
    </div>

    <nav class="auth-topbar">
        <a href="/" class="auth-topbar-logo">
            <img src="~/images/icons/Reservio.svg" alt="Reservio" />
        </a>
        <div class="auth-topbar-right">
            <div class="auth-topbar-currency">UAH</div>
            <div class="auth-topbar-flag">
                <svg width="30" height="20" viewBox="0 0 30 20" fill="none">
                    <rect width="30" height="10" fill="#0057B7"/>
                    <rect y="10" width="30" height="10" fill="#FFD700"/>
                </svg>
            </div>
            <a href="#" class="auth-topbar-help">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </a>
        </div>
    </nav>

    <main class="auth-main-figma">
        <form method="post" asp-action="RealtorRegisterStep1" asp-controller="Account">
            @Html.AntiForgeryToken()
            <div class="auth-card-figma">

                <div class="auth-form-content">

                    <!-- Step Indicator -->
                    <div class="rlt-steps">
                        <div class="rlt-step active">1</div>
                        <div class="rlt-step-sep"></div>
                        <div class="rlt-step">2</div>
                        <div class="rlt-step-sep"></div>
                        <div class="rlt-step">3</div>
                        <div class="rlt-step-sep"></div>
                        <div class="rlt-step">4</div>
                    </div>

                    <div style="display:flex;flex-direction:column;align-items:center;gap:8px;width:100%;">
                        <h1 class="auth-heading-figma" style="text-align:center;">Створення акаунту партнера</h1>
                        <p class="auth-subheading-figma" style="text-align:center;">
                            Створіть акаунт, щоб зареєструвати та керувати готелями та помешканнями.
                        </p>
                    </div>

                    <div class="auth-fields-group">
                        <div class="auth-field">
                            <div class="auth-field-label-row">
                                <label class="auth-field-label" for="Email">Електронна адреса</label>
                            </div>
                            <div class="auth-input-wrapper @(hasError ? "field-error" : "")">
                                <input type="email"
                                       class="auth-input-figma"
                                       id="Email"
                                       name="Email"
                                       value="@Model?.Email"
                                       placeholder="Введіть свою електронну адресу"
                                       autocomplete="email" />
                                @if (hasError)
                                {
                                    <span class="field-status-icon field-status-error">
                                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                            <circle cx="10" cy="10" r="9" stroke="#EB3D00" stroke-width="1.5"/>
                                            <line x1="10" y1="6" x2="10" y2="10.5" stroke="#EB3D00" stroke-width="1.5" stroke-linecap="round"/>
                                            <circle cx="10" cy="13.5" r="0.8" fill="#EB3D00"/>
                                        </svg>
                                    </span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (hasError)
                    {
                        <div class="auth-error-box">
                            <span class="auth-error-box-text">@ViewBag.Error</span>
                        </div>
                    }

                    <button type="submit" class="auth-submit-btn">Продовжити</button>
                </div>

                <div class="rlt-login-footer">
                    <p style="font-family:'Rubik',sans-serif;font-size:14px;color:#000;text-align:center;">Вже маєте акаунт?</p>
                    <a href="@Url.Action("RealtorLogin", "Account")" class="rlt-register-btn">Увійти</a>
                </div>

                <div class="auth-footer-figma" style="margin-top:16px;">
                    <p class="auth-footer-text">
                        Входячи в акаунт або створюючи новий, ви погоджуєтеся з нашими
                        <a href="#">Правилами й умовами</a> та <a href="#">Політикою конфіденційності</a>
                    </p>
                    <p class="auth-footer-copy">Усі права захищено.</p>
                    <p class="auth-footer-copy">Copyright (2006 - 2026) - Reservio&#8482;</p>
                </div>

            </div>
        </form>
    </main>

</div>
</body>
</html>
