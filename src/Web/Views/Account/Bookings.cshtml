@using Web.Models.Api
@{
    ViewData["Title"] = "Мої бронювання";
    Layout = null;
    ViewBag.ActiveTab = "Bookings";
    var apiBookings = ViewBag.ApiBookings as List<BookingApiDto> ?? new List<BookingApiDto>();
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reservio — Мої бронювання</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700&family=Unbounded:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>

@await Html.PartialAsync("_DashboardHero")

<div class="dsh-wrap">

    <!-- Sort / filter bar -->
    <div class="bk-sort-bar">
        <div class="bk-sort-wrap">
            <span class="bk-sort-label">Відсортувати за:</span>
            <select class="bk-sort-select" onchange="filterBookings(this.value)">
                <option value="all">Всі бронювання</option>
                <option value="paid">Оплачено</option>
                <option value="booked">Заброньовано</option>
                <option value="canceled">Скасовано</option>
            </select>
        </div>
    </div>

    <!-- Booking cards grid -->
    <div class="bk-grid" id="bkGrid">

        @if (!apiBookings.Any())
        {
            <div style="grid-column:1/-1;text-align:center;padding:48px 0;color:#777;">
                <p>У вас ще немає бронювань.</p>
                <a href="@Url.Action("Index","Home")" style="color:#E73D00;">Знайти готель</a>
            </div>
        }
        else
        {
            @foreach (var bk in apiBookings)
            {
                var hotel = bk.Hotel;
                var city = hotel.Address?.City?.Name ?? "";
                var country = hotel.Address?.City?.Country?.Name ?? "";
                var street = hotel.Address?.Street ?? "";
                var houseNum = hotel.Address?.HouseNumber ?? "";
                var addr = string.IsNullOrEmpty(street) ? city : $"{street} {houseNum}, {city}";
                var photo = hotel.Photos?.OrderBy(p => p.Priority).FirstOrDefault()?.Name;
                var imgUrl = string.IsNullOrEmpty(photo)
                    ? "~/images/property-1.jpg"
                    : $"http://localhost:5292/images/{photo}";
                var roomName = bk.BookingRoomVariants?.FirstOrDefault()?.RoomVariant?.GuestInfo is { } gi
                    ? $"{gi.AdultCount} дорослих · {gi.ChildCount} дітей"
                    : "—";
                var dateRange = $"{bk.DateFrom:dd MMMM} – {bk.DateTo:dd MMMM yyyy}";
                var now = DateOnly.FromDateTime(DateTime.Today);
                var statusLabel = bk.DateTo < now ? "Завершено" : "Заброньовано";
                var statusCss   = bk.DateTo < now ? "paid" : "booked";
                <div class="bk-card" data-status="@statusLabel">
                    <img class="bk-card-img" src="@imgUrl" alt="@hotel.Name" />
                    <div class="bk-card-body">
                        <div class="bk-hotel-name">@hotel.Name</div>
                        <div class="bk-hotel-city">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            @city@(string.IsNullOrEmpty(country) ? "" : $", {country}")
                        </div>
                        <div class="bk-hotel-addr">@addr</div>
                        <div class="bk-room-name">@roomName</div>
                        <div class="bk-detail-row">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                            @dateRange
                        </div>
                        <div class="bk-footer-row">
                            <div class="bk-status @statusCss">
                                <div class="bk-status-dot"></div>
                                @statusLabel
                            </div>
                            <div class="bk-price">UAH @bk.AmountToPay.ToString("N0")</div>
                        </div>
                        <a href="@Url.Action("BookingDetail","Account",new{id=bk.Id})" class="bk-btn-detail">Детальніше</a>
                    </div>
                </div>
            }
        }

    </div>
</div>

@await Html.PartialAsync("_DashboardFooter")

<script>
function filterBookings(val) {
    var cards = document.querySelectorAll('#bkGrid .bk-card');
    cards.forEach(function(c) {
        var status = c.getAttribute('data-status');
        c.style.display = (val === 'all' ||
            (val === 'paid' && status === 'Оплачено') ||
            (val === 'booked' && status === 'Заброньовано') ||
            (val === 'canceled' && status === 'Скасовано')) ? '' : 'none';
    });
}
</script>
</body>
</html>
