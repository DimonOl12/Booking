@{
    ViewData["Title"] = "Мої бронювання";
    Layout = null;
    ViewBag.ActiveTab = "Bookings";
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reservio — Мої бронювання</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700&family=Unbounded:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>

@await Html.PartialAsync("_DashboardHero")

<div class="dsh-wrap">

    <!-- Sort / filter bar -->
    <div class="bk-sort-bar">
        <div class="bk-sort-wrap">
            <span class="bk-sort-label">Відсортувати за:</span>
            <select class="bk-sort-select" onchange="filterBookings(this.value)">
                <option value="all">Всі бронювання</option>
                <option value="paid">Оплачено</option>
                <option value="booked">Заброньовано</option>
                <option value="canceled">Скасовано</option>
            </select>
        </div>
    </div>

    <!-- Booking cards grid -->
    <div class="bk-grid" id="bkGrid">

        <!-- Card 1: Атлас Делюкс — Оплачено -->
        <div class="bk-card" data-status="Оплачено">
            <img class="bk-card-img" src="~/images/property-1.jpg" alt="Атлас Делюкс" />
            <div class="bk-card-body">
                <div class="bk-hotel-name">Атлас Делюкс</div>
                <div class="bk-hotel-city">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Львів, Україна
                </div>
                <div class="bk-hotel-addr">Шевченка Проспект 27, Львів, 79006</div>
                <div class="bk-room-name">Стандартний двомісний номер або номер Твін</div>
                <div class="bk-detail-row">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                    10 – 11 лютого 2026
                </div>
                <div class="bk-detail-row">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    2 дорослих · 1 номер
                </div>
                <div class="bk-footer-row">
                    <div class="bk-status paid">
                        <div class="bk-status-dot"></div>
                        Оплачено
                    </div>
                    <div class="bk-price">UAH 3 591</div>
                </div>
                <a href="@Url.Action("BookingDetail","Account",new{id=1})" class="bk-btn-detail">Детальніше</a>
            </div>
        </div>

        <!-- Card 2: Готель Швейцарський — Заброньовано -->
        <div class="bk-card" data-status="Заброньовано">
            <img class="bk-card-img" src="~/images/property-2.jpg" alt="Готель Швейцарський" />
            <div class="bk-card-body">
                <div class="bk-hotel-name">Готель Швейцарський</div>
                <div class="bk-hotel-city">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Львів, Україна
                </div>
                <div class="bk-hotel-addr">Кн. Романа Вул.20, Львів, 79005</div>
                <div class="bk-room-name">Покращений сімейний номер</div>
                <div class="bk-detail-row">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                    22 – 23 травня 2026
                </div>
                <div class="bk-detail-row">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    2 дорослих · 1 номер
                </div>
                <div class="bk-footer-row">
                    <div class="bk-status booked">
                        <div class="bk-status-dot"></div>
                        Заброньовано
                    </div>
                    <div class="bk-price">UAH 4 250</div>
                </div>
                <a href="@Url.Action("BookingDetail","Account",new{id=2})" class="bk-btn-detail">Детальніше</a>
            </div>
        </div>

        <!-- Card 3: PANORAMA Lviv Hotel — Заброньовано -->
        <div class="bk-card" data-status="Заброньовано">
            <img class="bk-card-img" src="~/images/property-3.jpg" alt="PANORAMA Lviv Hotel" />
            <div class="bk-card-body">
                <div class="bk-hotel-name">PANORAMA Lviv Hotel</div>
                <div class="bk-hotel-city">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Львів, Україна
                </div>
                <div class="bk-hotel-addr">Проспект свободи 45, Львів, 79007</div>
                <div class="bk-room-name">Люкс</div>
                <div class="bk-detail-row">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                    18 – 19 лютого 2026
                </div>
                <div class="bk-detail-row">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    2 дорослих · 1 номер
                </div>
                <div class="bk-footer-row">
                    <div class="bk-status booked">
                        <div class="bk-status-dot"></div>
                        Заброньовано
                    </div>
                    <div class="bk-price">UAH 9 600</div>
                </div>
                <a href="@Url.Action("BookingDetail","Account",new{id=3})" class="bk-btn-detail">Детальніше</a>
            </div>
        </div>

        <!-- Card 4: Готель Шопен — Скасовано -->
        <div class="bk-card" data-status="Скасовано">
            <img class="bk-card-img" src="~/images/property-4.jpg" alt="Готель Шопен" />
            <div class="bk-card-body">
                <div class="bk-hotel-name">Готель Шопен</div>
                <div class="bk-hotel-city">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Львів, Україна
                </div>
                <div class="bk-hotel-addr">Площа Маланки, 3, Львів, 79500</div>
                <div class="bk-room-name">Стандартний двомісний номер</div>
                <div class="bk-detail-row">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
                    10 – 11 липня 2026
                </div>
                <div class="bk-detail-row">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    2 дорослих · 1 номер
                </div>
                <div class="bk-footer-row">
                    <div class="bk-status canceled">
                        <div class="bk-status-dot"></div>
                        Скасовано
                    </div>
                    <div class="bk-price">UAH 4 700</div>
                </div>
                <a href="@Url.Action("Bookings","Account")" class="bk-btn-rebook">Забронювати знову</a>
            </div>
        </div>

    </div>
</div>

@await Html.PartialAsync("_DashboardFooter")

<script>
function filterBookings(val) {
    var cards = document.querySelectorAll('#bkGrid .bk-card');
    cards.forEach(function(c) {
        var status = c.getAttribute('data-status');
        c.style.display = (val === 'all' ||
            (val === 'paid' && status === 'Оплачено') ||
            (val === 'booked' && status === 'Заброньовано') ||
            (val === 'canceled' && status === 'Скасовано')) ? '' : 'none';
    });
}
</script>
</body>
</html>
