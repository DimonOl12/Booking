@model Web.Models.RealtorRatingViewModel
@{
    ViewData["Title"] = "Рейтинг";
    Layout = null;
    ViewBag.ActiveTab = "Rating";
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reservio — Рейтинг</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700&family=Unbounded:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/realtor-dashboard.css" />
</head>
<body>
<div class="rdsh-page">

    @await Html.PartialAsync("_RealtorDashboardHero")

    <main class="rdsh-main">

        @if (Model == null || !Model.HasRating)
        {
            <!-- ── EMPTY STATE ─────────────────────────────── -->
            <div class="rdsh-white-card rrat-card">
                <div class="rrat-top">
                    <h1 class="rrat-title">У вас поки немає рейтингу</h1>
                    <p class="rrat-subtitle">Рейтинг з'явиться після того, як гості залишають перші відгуки після проживання</p>
                </div>
                <div class="rrat-body">
                    <div class="rrat-empty-card">
                        <div class="rrat-mascot"></div>
                        <div class="rrat-empty-text">
                            <p class="rrat-empty-title">Немає відгуків</p>
                            <p class="rrat-empty-sub">Публікуйте оголошення та приймайте бронювання</p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            var m = Model;

            <!-- ── Page header ─────────────────────────────── -->
            <div class="rrat-page-header">
                <h1 class="rrat-title">Мій рейтинг</h1>
                <p class="rrat-subtitle">Ваша репутація та відгуки клієнтів</p>
            </div>

            <!-- ── Section 1: Summary + Categories ────────── -->
            <div class="rdsh-white-card rrat-sum-card">
                <div class="rrat-sum-inner">
                    <!-- Score column -->
                    <div class="rrat-score-col">
                        <div class="rrat-score-row">
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <span class="rrat-score-big">@m.OverallRating.ToString("0.0")/10</span>
                        </div>
                        <p class="rrat-score-label">@m.RatingLabel</p>
                        <p class="rrat-score-count">@m.ReviewCount перевірених відгуків</p>
                    </div>

                    <!-- Category bars -->
                    <div class="rrat-cats-col">
                        <p class="rrat-cats-heading">Категорії:</p>
                        <p class="rrat-cats-sub">Оцінки формуються на основі відгуків гостей після завершення проживання</p>
                        <div class="rrat-cats-list">
                            @foreach (var cat in m.Categories)
                            {
                                var pct = (int)(cat.Score / 10m * 100);
                                <div class="rrat-cat-item">
                                    <div class="rrat-cat-label-row">
                                        <span class="rrat-cat-name">@cat.Name</span>
                                        <span class="rrat-cat-score">@cat.Score.ToString("0.0")</span>
                                    </div>
                                    <div class="rrat-bar-track">
                                        <div class="rrat-bar-fill" style="width:@pct%"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Section 2: Rating Trend ─────────────────── -->
            <div class="rdsh-white-card rrat-trend-card">
                <div class="rrat-trend-head">
                    <h2 class="rrat-section-title">Як змінювався рейтинг</h2>
                    <p class="rrat-subtitle">Рейтинг формується на основі відгуків після завершення проживання</p>
                </div>
                <div class="rrat-trend-body">
                    <!-- Chart -->
                    <div class="rrat-chart-wrap">
                        <canvas id="ratingChart"></canvas>
                    </div>
                    <!-- Tips card -->
                    <div class="rrat-tips-card">
                        <p class="rrat-tips-title">Хочете покращити рейтинг?</p>
                        <div class="rrat-tips-grid">
                            <div class="rrat-tips-col">
                                <div class="rrat-tip-row">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="15" y2="13"/></svg>
                                    Відповідайте швидко
                                </div>
                                <div class="rrat-tip-row">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                                    Підтримуйте чистоту
                                </div>
                                <div class="rrat-tip-row">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="13" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                                    Додавайте реальні фото
                                </div>
                                <div class="rrat-tip-row">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                                    Будьте на зв'язку з гостями
                                </div>
                            </div>
                            <div class="rrat-tips-col">
                                <div class="rrat-tip-row">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    Підтвердьте контактні дані
                                </div>
                                <div class="rrat-tip-row">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                    Аналіз слабких категорій
                                </div>
                                <div class="rrat-tip-row">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                    Проактивний збір відгуків
                                </div>
                                <div class="rrat-tip-row">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                                    Підтримка високого коефіцієнта прийняття бронювань
                                </div>
                            </div>
                        </div>
                        <!-- Info/mascot card -->
                        <div class="rdsh-info-card">
                            <div class="rdsh-info-text">
                                <p class="rdsh-info-title">Як формується оцінка?</p>
                                <p class="rdsh-info-sub">Гість виставляє бали за окремими категоріями після завершення проживання. Загальна оцінка формується на основі середнього значення цих показників.</p>
                            </div>
                            <div class="rdsh-info-mascot"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Section 3: Last Review ──────────────────── -->
            @if (m.LastReview != null)
            {
                var rv = m.LastReview;
                <div class="rdsh-white-card rrat-rev-outer">
                    <div class="rrat-rev-header">
                        <h2 class="rrat-section-title">Останній відгук гостя</h2>
                        <a href="@Url.Action("RealtorMyAds","Account")" class="rrat-viewall-btn">
                            Переглянути всі
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                        </a>
                    </div>
                    <div class="rrat-rev-body">
                        <!-- Left: guest profile -->
                        <div class="rrat-guest-panel">
                            <img class="rrat-guest-avatar" src="https://placehold.co/150x150/D9D9D9/999?text=..." alt="@rv.GuestName" />
                            <p class="rrat-guest-name">@rv.GuestName</p>
                            <p class="rrat-guest-loc">@rv.GuestLocation</p>
                            <div class="rrat-guest-meta">
                                <div class="rrat-meta-row">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                    @rv.PropertyName
                                </div>
                                <div class="rrat-meta-row">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                    @rv.Stay
                                </div>
                                <div class="rrat-meta-row">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    @rv.Guests
                                </div>
                            </div>
                        </div>

                        <!-- Right: review content + reply -->
                        <div class="rrat-rev-content">
                            <div class="rrat-rev-main">
                                <h3 class="rrat-rev-title">@rv.ReviewTitle</h3>
                                @foreach (var para in rv.ReviewParagraphs)
                                {
                                    <p class="rrat-rev-para">@para</p>
                                }
                                <div class="rrat-rev-foot">
                                    <span class="rrat-rev-foot-label">Загальна оцінка помешкання</span>
                                    <div class="rrat-rating-badge">
                                        <span class="rrat-badge-score">@rv.Rating.ToString("0.0")</span>
                                        <span class="rrat-badge-label">@rv.RatingLabel</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Owner reply -->
                            <div class="rrat-reply-card">
                                <div class="rrat-reply-head">
                                    <div>
                                        <p class="rrat-reply-title">Відповідь</p>
                                        <p class="rrat-reply-sub">Рієлтор</p>
                                    </div>
                                    <a href="@Url.Action("RealtorMessages","Account")" class="rrat-chat-link">Переглянути в чаті</a>
                                </div>
                                <div class="rrat-reply-body">
                                    @foreach (var line in rv.OwnerReply.Split('\n', StringSplitOptions.None))
                                    {
                                        if (string.IsNullOrWhiteSpace(line)) { <br /> } else { <span>@line</span> }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }

    </main>

    @await Html.PartialAsync("_DashboardFooter")

</div>

@if (Model?.HasRating == true)
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
    (function () {
        var ratings = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRatings));
        var ctx = document.getElementById('ratingChart').getContext('2d');
        var grad = ctx.createLinearGradient(0, 0, 0, 280);
        grad.addColorStop(0, 'rgba(34,51,0,0.55)');
        grad.addColorStop(1, 'rgba(242,242,242,0.10)');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Січ','Лют','Бер','Квіт','Трав','Черв','Лип','Серп','Вер','Жовт','Лист','Груд'],
                datasets: [{
                    data: ratings,
                    borderColor: '#223300',
                    backgroundColor: grad,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5,
                    pointBackgroundColor: '#223300'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => 'Рейтинг: ' + c.parsed.y } } },
                scales: {
                    x: { grid: { color: '#C1C6B8' }, ticks: { font: { family: 'Rubik', size: 12 } } },
                    y: { min: 5, max: 10, grid: { color: '#C1C6B8' }, ticks: { font: { family: 'Rubik', size: 12 }, stepSize: 1 } }
                }
            }
        });
    })();
    </script>
}
</body>
</html>
