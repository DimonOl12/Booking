@{
    ViewData["Title"] = "Відновлення паролю — Успішно";
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reservio — Відновлення паролю</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700&family=Unbounded:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>
<div class="auth-page-figma">

    <!-- Background Image -->
    <div class="auth-hero-bg">
        <img src="~/images/Subtract.jpg" alt="" />
    </div>

    <!-- Top Navbar -->
    <nav class="auth-topbar">
        <a href="/" class="auth-topbar-logo">
            <img src="~/images/icons/Reservio.svg" alt="Reservio" />
        </a>
        <div class="auth-topbar-right">
            <div class="auth-topbar-currency">UAH</div>
            <div class="auth-topbar-flag">
                <svg width="30" height="20" viewBox="0 0 30 20" fill="none">
                    <rect width="30" height="10" fill="#0057B7"/>
                    <rect y="10" width="30" height="10" fill="#FFD700"/>
                </svg>
            </div>
            <a href="#" class="auth-topbar-help">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#777" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="auth-main-figma">
        <div class="auth-card-figma" style="padding-bottom:40px;">

            <!-- Step Indicators -->
            <div class="auth-steps">
                <div class="auth-step-item">1</div>
                <div class="auth-step-item">2</div>
                <div class="auth-step-item active">3</div>
            </div>

            <!-- Form Content -->
            <div class="auth-form-content">
                <h1 class="auth-heading-figma">Відновлення паролю</h1>
                <p class="auth-subheading-figma" style="max-width:100%;">
                    Ваш пароль успішно відновлений, натисніть нижче, щоб продовжити
                </p>
                <a href="@Url.Action("Login", "Account")" class="auth-submit-btn">Повернутися до входу</a>
            </div>

        </div>
    </main>

</div>
</body>
</html>
