@{
    var fullName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";
    var initials = User.FindFirst("Initials")?.Value ?? "?";
}
<nav class="home-navbar">
    <a href="/" class="home-navbar-logo">
        <img src="~/images/icons/Reservio.svg" alt="Reservio" style="width:159.848px;height:30.074px;flex-shrink:0;" />
    </a>
    <div class="home-navbar-right">
        <div class="home-navbar-currency">UAH</div>
        <div class="home-navbar-flag">
            <svg width="30" height="20" viewBox="0 0 30 20" fill="none">
                <rect width="30" height="10" fill="#0057B7"/>
                <rect y="10" width="30" height="10" fill="#FFD700"/>
            </svg>
        </div>
        <a href="@Url.Action("Realtor", "Home")" class="nav-text nav-text-desktop">Зареєструвати своє помешкання</a>

        <!-- User dropdown -->
        <div class="home-navbar-user-wrap" id="userDropdownWrap">
            <button class="home-navbar-user" id="userDropdownBtn" type="button" aria-haspopup="true" aria-expanded="false">
                <div class="home-navbar-avatar">@initials</div>
                <span class="home-navbar-username">@fullName</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;flex-shrink:0;">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </button>
            <div class="home-navbar-dropdown" id="userDropdown">
                <a href="@Url.Action("Profile", "Account")" class="dropdown-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Особисті дані
                </a>
                <a href="#" class="dropdown-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Мої бронювання
                </a>
                <a href="#" class="dropdown-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    Збережені
                </a>
                <div class="dropdown-divider"></div>
                <form method="post" asp-action="Logout" asp-controller="Account" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="dropdown-item dropdown-item-logout">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Вийти
                    </button>
                </form>
            </div>
        </div>
    </div>
</nav>

<script>
    (function () {
        var wrap = document.getElementById('userDropdownWrap');
        var btn = document.getElementById('userDropdownBtn');
        var menu = document.getElementById('userDropdown');
        if (!wrap || !btn || !menu) return;

        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var open = menu.classList.toggle('open');
            btn.setAttribute('aria-expanded', open);
        });

        document.addEventListener('click', function (e) {
            if (!wrap.contains(e.target)) {
                menu.classList.remove('open');
                btn.setAttribute('aria-expanded', 'false');
            }
        });
    })();
</script>
