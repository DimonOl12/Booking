@using System.Security.Claims
@{
    var activeTab = ViewBag.ActiveTab as string ?? "Profile";
    var initials  = User.FindFirst("Initials")?.Value ?? "?";
    var fullName  = User.Identity?.Name ?? "";
    if (string.IsNullOrEmpty(fullName))
        fullName = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
}

<div class="dsh-hero">
    <img class="dsh-hero-img" src="~/images/Subtract.jpg" alt="" />

    <!-- ── Navbar ── -->
    <nav class="dsh-navbar">
        <a href="/" class="dsh-navbar-logo">
            <img src="~/images/icons/Reservio.svg" alt="Reservio" />
        </a>
        <div class="dsh-navbar-right">
            <div class="dsh-navbar-currency">UAH</div>
            <div class="dsh-navbar-flag">
                <svg width="30" height="20" viewBox="0 0 30 20" fill="none">
                    <rect width="30" height="10" fill="#0057B7"/>
                    <rect y="10" width="30" height="10" fill="#FFD700"/>
                </svg>
            </div>
            <a href="@Url.Action("Realtor","Home")" class="dsh-navbar-text-link">Зареєструвати своє помешкання</a>

            <div class="dsh-user-wrap" id="dshUserWrap">
                <button class="dsh-user-btn" id="dshUserBtn" type="button">
                    <div class="dsh-avatar-wrap">
                        <div class="dsh-avatar">@initials</div>
                        <span class="dsh-badge">3</span>
                    </div>
                    <span class="dsh-username">@fullName</span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <div class="dsh-dropdown" id="dshDrop">
                    <a href="@Url.Action("Profile","Account")" class="dsh-drop-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Особисті дані
                    </a>
                    <a href="@Url.Action("Bookings","Account")" class="dsh-drop-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Мої бронювання
                    </a>
                    <a href="@Url.Action("Saved","Account")" class="dsh-drop-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        Збережені
                    </a>
                    <div class="dsh-drop-divider"></div>
                    <form method="post" asp-action="Logout" asp-controller="Account" style="margin:0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dsh-drop-item logout">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                            Вийти
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <!-- ── Tabs bar ── -->
    <div class="dsh-tabs-bar">
        @* Profile *@
        @if (activeTab == "Profile") {
            <div class="dsh-tab-chip">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Особисті дані
            </div>
        } else {
            <a href="@Url.Action("Profile","Account")" class="dsh-tab-icon" title="Особисті дані">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </a>
        }

        @* Messages *@
        @if (activeTab == "Messages") {
            <div class="dsh-tab-chip">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                Повідомлення
            </div>
        } else {
            <a href="@Url.Action("Messages","Account")" class="dsh-tab-icon" title="Повідомлення">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
        }

        @* Bookings *@
        @if (activeTab == "Bookings") {
            <div class="dsh-tab-chip">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Бронювання
            </div>
        } else {
            <a href="@Url.Action("Bookings","Account")" class="dsh-tab-icon" title="Бронювання">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </a>
        }

        @* Saved *@
        @if (activeTab == "Saved") {
            <div class="dsh-tab-chip">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                Збережені
            </div>
        } else {
            <a href="@Url.Action("Saved","Account")" class="dsh-tab-icon" title="Збережені">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            </a>
        }

        @* Settings *@
        @if (activeTab == "Settings") {
            <div class="dsh-tab-chip">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                Налаштування
            </div>
        } else {
            <a href="@Url.Action("Settings","Account")" class="dsh-tab-icon" title="Налаштування">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </a>
        }

        @* Payment *@
        @if (activeTab == "Payment") {
            <div class="dsh-tab-chip">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                Оплата
            </div>
        } else {
            <a href="@Url.Action("Payment","Account")" class="dsh-tab-icon" title="Способи оплати">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#223300" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            </a>
        }
    </div>
</div>

<script>
(function () {
    var wrap = document.getElementById('dshUserWrap');
    var btn  = document.getElementById('dshUserBtn');
    var menu = document.getElementById('dshDrop');
    if (!wrap) return;
    btn.addEventListener('click', function (e) {
        e.stopPropagation();
        menu.classList.toggle('open');
    });
    document.addEventListener('click', function (e) {
        if (!wrap.contains(e.target)) menu.classList.remove('open');
    });
})();
</script>
